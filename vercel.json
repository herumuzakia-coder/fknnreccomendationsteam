{
  "version": 2,
  "builds": [
    {
      "src": "serve.mjs",
      "use": "@vercel/node",
      "config": { "includeFiles": ["assets/**"] }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/serve.mjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
